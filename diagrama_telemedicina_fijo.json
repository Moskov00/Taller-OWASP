            "threats": [
              {
                "id": "threat-005",
                "title": "Inyeccion SQL en Modulo de Autenticacion",
                "status": "Open",
                "severity": "Critical",
                "type": "Tampering",
                "description": "Un atacante podria manipular los campos de login para ejecutar consultas SQL maliciosas y bypassear la autenticacion.",
                "mitigation": "Usar consultas parametrizadas (prepared statements) y ORM. Validar y sanitizar todos los inputs del usuario.",
                "modelType": "STRIDE"
              },
              {
                "id": "threat-006",
                "title": "Denegacion de Servicio en Agendamiento",
                "status": "Open",
                "severity": "High",
                "type": "DenialOfService",
                "description": "Un atacante podria inundar el modulo de citas con solicitudes masivas, impidiendo a pacientes legitimos agendar.",
                "mitigation": "Implementar rate limiting por IP y por sesion. Usar CAPTCHA en el formulario de agendamiento.",
                "modelType": "STRIDE"
              },
              {
                "id": "threat-007",
                "title": "Fuga de Tokens de Sesion",
                "status": "Open",
                "severity": "High",
                "type": "InformationDisclosure",
                "description": "Los tokens JWT podrian ser interceptados si no se gestiona correctamente su almacenamiento y transmision.",
                "mitigation": "Usar HTTPS/TLS 1.3. Almacenar tokens en HttpOnly cookies. Implementar rotacion y expiracion de tokens.",
                "modelType": "STRIDE"
              }
            ],
            "attrs": {
              "text": { "text": "Modulo de\nAutenticacion\ny Citas" }
            }
