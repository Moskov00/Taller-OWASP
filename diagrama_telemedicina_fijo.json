            "threats": [
              {
                "id": "threat-001",
                "title": "Suplantacion de Identidad del Paciente",
                "status": "Open",
                "severity": "High",
                "type": "Spoofing",
                "description": "Un atacante podria hacerse pasar por un paciente legitimo para acceder a citas o historial medico ajeno.",
                "mitigation": "Implementar autenticacion multifactor (MFA) con OTP via SMS o aplicacion autenticadora.",
                "modelType": "STRIDE"
              },
              {
                "id": "threat-002",
                "title": "Repudio de Solicitudes de Citas",
                "status": "Open",
                "severity": "Medium",
                "type": "Repudiation",
                "description": "El paciente podria negar haber solicitado o cancelado una cita medica.",
                "mitigation": "Registrar logs de auditoria firmados digitalmente con timestamp para todas las acciones del paciente.",
                "modelType": "STRIDE"
              }
            ],
            "attrs": {
              "text": { "text": "Paciente\n(Ciudadano)" }
            }
          },
          {
            "type": "tm.Actor",
