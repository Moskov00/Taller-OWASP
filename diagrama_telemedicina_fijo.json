            "threats": [
              {
                "id": "threat-003",
                "title": "Suplantacion de Medico Especialista",
                "status": "Open",
                "severity": "Critical",
                "type": "Spoofing",
                "description": "Un actor malicioso podria suplantar a un medico para acceder o modificar historiales clinicos de pacientes.",
                "mitigation": "Autenticacion con certificado digital profesional y validacion de credenciales medicas contra registro oficial.",
                "modelType": "STRIDE"
              },
              {
                "id": "threat-004",
                "title": "Elevacion de Privilegios del Medico",
                "status": "Open",
                "severity": "High",
                "type": "ElevationOfPrivilege",
                "description": "Un medico con acceso limitado podria intentar acceder a expedientes de pacientes fuera de su asignacion.",
                "mitigation": "Control de acceso basado en roles (RBAC) con restriccion por paciente asignado. Auditorias periodicas.",
                "modelType": "STRIDE"
              }
            ],
            "attrs": {
              "text": { "text": "Medico\n(Especialista)" }
            }
          },
