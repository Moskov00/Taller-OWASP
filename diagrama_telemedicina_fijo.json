            "threats": [
              {
                "id": "threat-008",
                "title": "Acceso No Autorizado a Historial Clinico",
                "status": "Open",
                "severity": "Critical",
                "type": "InformationDisclosure",
                "description": "Un usuario sin autorizacion podria visualizar el expediente medico completo de un paciente (violacion HIPAA/GDPR).",
                "mitigation": "Cifrado de datos en reposo y en transito. Control de acceso granular. Enmascaramiento de datos sensibles.",
                "modelType": "STRIDE"
              },
              {
                "id": "threat-009",
                "title": "Modificacion Maliciosa de Expediente Medico",
                "status": "Open",
                "severity": "Critical",
                "type": "Tampering",
                "description": "Un atacante interno podria alterar diagnosticos, medicaciones o resultados de laboratorio en el historial.",
                "mitigation": "Firma digital de registros medicos. Versionado inmutable de cambios. Logs de auditoria con hash.",
                "modelType": "STRIDE"
              },
              {
                "id": "threat-010",
                "title": "Repudio de Modificaciones al Historial",
                "status": "Open",
                "severity": "High",
                "type": "Repudiation",
                "description": "Un medico podria negar haber modificado un expediente medico de forma incorrecta.",
                "mitigation": "Implementar firma digital por parte del medico en cada modificacion. Logs de no repudio.",
                "modelType": "STRIDE"
              }
            ],
            "attrs": {
              "text": { "text": "Modulo de\nConsulta e\nHistorial" }
